{
  "name": "clearsight",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/dev-preflight.mjs",
    "dev": "next dev -p 3000",
    "dev:clean": "node scripts/dev-preflight.mjs --force && next dev -p 3000",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && node scripts/migrate-deploy.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "i18n:gen": "node scripts/translate-ui.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "node scripts/migrate-deploy.mjs",
    "db:seed": "prisma db seed",
    "db:setup": "node scripts/db-setup.mjs",
    "db:refresh-stories": "node scripts/refresh-stories.mjs",
    "db:cleanup-delinquent": "node scripts/cleanup-delinquent.mjs",
    "generate:music": "node scripts/generate-music.mjs",
    "generate:host-art": "node scripts/generate-host-art.mjs",
    "generate:pwa-icons": "node scripts/upload-pwa-icons.mjs",
    "generate:show-intros": "node scripts/generate-show-intros.mjs",
    "generate:vapid": "node scripts/generate-vapid-keys.mjs",
    "db:gcp": "node scripts/start-gcp-db.mjs",
    "db:push": "node scripts/db-push.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^2.4.0",
    "google-auth-library": "^10.7.0",
    "inngest": "^4.7.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
