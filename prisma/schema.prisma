generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Plan {
  FREE
  PREMIUM
  CREATOR
}

enum CreditTxnType {
  SUBSCRIPTION
  PURCHASE
  GENERATION
  REFUND
  ADJUSTMENT
}

enum GenerationStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                   String       @id @default(cuid())
  whopUserId           String?      @unique
  email                String?      @unique
  name                 String?
  passwordHash         String?
  affiliateCode        String?
  plan                 Plan         @default(FREE)
  coreTokens           Int          @default(0)
  subscriptionActive   Boolean      @default(false)
  subscriptionCycleStart DateTime?
  // Set when a subscription lapses. Delinquent account data is retained for 60
  // days from this timestamp and then purged by the cleanup job.
  delinquentSince      DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  generations          Generation[]
  sessions             Session[]
  passwordResets       PasswordResetToken[]
  creditTransactions   CreditTransaction[]
  pushSubscriptions    PushSubscription[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model CreditTransaction {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Int
  balanceAfter Int
  type         CreditTxnType
  description  String?
  createdAt    DateTime      @default(now())

  @@index([userId, createdAt])
}

model Story {
  id               String   @id @default(cuid())
  title            String
  language         String
  category         String
  geoScope         String
  geoRegion        String?
  geoCountry       String?
  geoState         String?
  geoLocal         String?
  markdownContent  String   @db.Text
  audioUrl         String?
  thumbnailUrl     String?
  durationSeconds  Int?
  reliabilityIndex Float?
  sourcesVerified  Json?
  isCached         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([language, category, geoScope])
  @@index([language, category, geoScope, geoCountry])
}

model Generation {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId              String?
  taxonomyKey          String
  tokenConsumed        Boolean          @default(true)
  // Background-job lifecycle. Generation now runs asynchronously via Inngest;
  // these fields track its state so the client can poll and the worker can
  // resume/refund on failure.
  status               GenerationStatus @default(QUEUED)
  params               Json?
  includeIllustrations Boolean          @default(false)
  creditsCharged       Int              @default(1)
  errorMessage         String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt @default(now())

  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model AffiliateReferral {
  id             String   @id @default(cuid())
  affiliateCode  String
  referredUserId String?
  whopPaymentId  String?  @unique
  payoutAmount   Decimal? @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  @@index([affiliateCode])
}
