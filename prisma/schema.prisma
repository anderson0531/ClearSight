generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Plan {
  FREE
  PREMIUM
  CREATOR
}

enum CreditTxnType {
  SUBSCRIPTION
  PURCHASE
  GENERATION
  REFUND
  ADJUSTMENT
}

enum GenerationStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id                   String       @id @default(cuid())
  whopUserId           String?      @unique
  email                String?      @unique
  name                 String?
  passwordHash         String?
  affiliateCode        String?
  plan                 Plan         @default(FREE)
  // Stored in credit units (1 displayed credit = 100 units). See src/lib/credit-units.ts.
  coreTokens           Int          @default(0)
  subscriptionActive   Boolean      @default(false)
  subscriptionCycleStart DateTime?
  // Set when a subscription lapses. Delinquent account data is retained for 60
  // days from this timestamp and then purged by the cleanup job.
  delinquentSince      DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  generations          Generation[]
  sessions             Session[]
  passwordResets       PasswordResetToken[]
  creditTransactions   CreditTransaction[]
  pushSubscriptions    PushSubscription[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model CreditTransaction {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stored in credit units (1 displayed credit = 100 units). See src/lib/credit-units.ts.
  amount       Int
  balanceAfter Int
  type         CreditTxnType
  description  String?
  createdAt    DateTime      @default(now())

  @@index([userId, createdAt])
}

model Story {
  id               String   @id @default(cuid())
  title            String
  language         String
  category         String
  geoScope         String
  geoRegion        String?
  geoCountry       String?
  geoState         String?
  geoLocal         String?
  markdownContent  String   @db.Text
  audioUrl         String?
  thumbnailUrl     String?
  durationSeconds  Int?
  reliabilityIndex Float?
  sourcesVerified  Json?
  isCached         Boolean  @default(true)

  // Link to the original story that this was updated from
  originalStoryId    String?
  originalStory      Story?    @relation("StoryLineage", fields: [originalStoryId], references: [id])
  updatedVersions    Story[]   @relation("StoryLineage")

  // Stores the calculated accuracy score (e.g., 85.0) from the previous briefing's claims
  priorAccuracyScore Float?

  // Shared engagement counters (YouTube-style). likeCount/dislikeCount are
  // denormalized and kept in sync with StoryReaction rows transactionally.
  viewCount        Int      @default(0)
  likeCount        Int      @default(0)
  dislikeCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  reactions        StoryReaction[]
  questions        StoryQuestion[]

  @@index([language, category, geoScope])
  @@index([language, category, geoScope, geoCountry])
}

model StoryReaction {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  // 1 = thumbs up, -1 = thumbs down. A user has at most one reaction per story.
  value     Int
  // Optional structured reason id for the rating (see src/lib/reaction-reasons.ts).
  // Cleared when the vote is removed. Validated against the vote polarity.
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storyId, userId])
  @@index([storyId])
}

model StoryQuestion {
  id                 String   @id @default(cuid())
  storyId            String
  story              Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  // The user who asked. Not a FK so a Q&A survives if the asker is purged.
  userId             String
  // Answer language (English name, e.g. "Spanish").
  language           String
  // Original user text and the moderated/reframed question that was answered.
  rawQuestion        String   @db.Text
  question           String   @db.Text
  answerText         String   @db.Text
  // Which host answered (for attribution in the UI).
  responderName      String
  responderShortName String
  responderRole      String
  // Synthesized answer audio (first segment url) + per-line segments for
  // captioned playback with host portraits. Audio is produced asynchronously
  // (background job) after the text answer is delivered, so these stay null
  // until ready. `audioStatus` is one of: pending | ready | failed.
  audioUrl           String?
  durationSeconds    Int?
  segments           Json?
  audioStatus        String   @default("pending")
  // Stored in credit units (1 displayed credit = 100 units). See src/lib/credit-units.ts.
  creditsCharged     Int      @default(25)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([storyId, createdAt])
}

model Generation {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId              String?
  taxonomyKey          String
  tokenConsumed        Boolean          @default(true)
  // Background-job lifecycle. Generation now runs asynchronously via Inngest;
  // these fields track its state so the client can poll and the worker can
  // resume/refund on failure.
  status               GenerationStatus @default(QUEUED)
  // Fine-grained pipeline phase for the live progress UI (e.g. "analysis",
  // "audio", "thumbnail", "illustrations"). The worker advances this as each
  // step starts; the client maps it to a percentage + activity label.
  stage                String?          @default("queued")
  params               Json?
  includeIllustrations Boolean          @default(false)
  // Stored in credit units (1 displayed credit = 100 units). See src/lib/credit-units.ts.
  creditsCharged       Int              @default(100)
  errorMessage         String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt @default(now())

  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model ChannelIntroAudio {
  id            String           @id @default(cuid())
  showId        String
  language      String
  status        GenerationStatus @default(QUEUED)
  audioUrl      String?
  audioSegments Json?
  errorMessage  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([showId, language])
  @@index([showId])
}

model AffiliateReferral {
  id             String   @id @default(cuid())
  affiliateCode  String
  referredUserId String?
  whopPaymentId  String?  @unique
  payoutAmount   Decimal? @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  @@index([affiliateCode])
}
